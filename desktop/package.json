{
  "name": "mvt-insight-desktop",
  "version": "1.0.26",
  "description": "MVT Insight — App de escritorio para recolectar datos forenses de Android/iOS y subirlos a spyware.rpjsoftware.com",
  "main": "electron/main.cjs",
  "private": true,
  "author": {
    "name": "Jorge Plaza",
    "email": "soporte@spyware.rpjsoftware.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JORGEPLAZA499/mvt-insight.git"
  },
  "homepage": "https://spyware.rpjsoftware.com",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite build && electron .",
    "dist:win": "vite build && electron-builder --win --publish always",
    "dist:mac": "vite build && electron-builder --mac --publish always",
    "dist:linux": "vite build && electron-builder --linux --publish always"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "electron-updater": "^6.8.3",
    "i18next": "^23.15.2",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.1"
  },
  "build": {
    "appId": "com.jorgeplaza.mvtinsight",
    "productName": "MvtInsight",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "build-resources/icon.ico",
      "build-resources/icon.png",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "JORGEPLAZA499",
        "repo": "mvt-insight",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MvtInsight-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MvtInsight",
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico"
    },
    "mac": {
      "icon": "build-resources/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "MvtInsight-${version}-${arch}.${ext}",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MvtInsight-${version}.${ext}",
      "category": "Utility"
    }
  }
}
